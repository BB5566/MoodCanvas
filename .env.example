# MoodCanvas Environment Configuration
# 複製此檔案為 .env 並填入真實的 API 密鑰和配置

# ====================================================================
# AI 服務配置
# ====================================================================

# DeepSeek (文字生成 - 必須)
# 註冊：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="sk-your-key-here"

# Replicate (圖片生成 - 必須)
# 註冊：https://replicate.com/account/api-tokens
# 模型：google/imagen-4
REPLICATE_API_KEY="r8_your-token-here"

# Pioneer (備援 AI，可選)
# 註冊：https://pioneer.ai
PIONEER_API_KEY="pio_sk_your-key-here"

# ====================================================================
# 資料庫配置
# ====================================================================

DB_HOST=portfolio-db
DB_PORT=3306
DB_NAME=mood_canvas_db
DB_USER=mood_user
DB_PASS=your_secure_password

# ====================================================================
# 應用程式配置
# ====================================================================

DEBUG=false
APP_URL=https://your-domain.com

# ====================================================================
# 安全設定
# ====================================================================

SESSION_TIMEOUT=3600
RATE_LIMIT_ENABLED=true
